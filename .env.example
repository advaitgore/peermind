# Required
ANTHROPIC_API_KEY=

# Optional: Semantic Scholar API key for higher rate limits (free tier works without)
SEMANTIC_SCHOLAR_API_KEY=

# Runtime config
LATEX_COMPILE_TIMEOUT=60
MAX_REVIEW_ROUNDS=3
CRITIQUE_DELTA_THRESHOLD=0.15
JOB_STORAGE_PATH=/tmp/peermind_jobs

# If you have Claude Managed Agents multiagent research preview access, set to true
# to enable native callable_agents delegation on the orchestrator.
MANAGED_AGENTS_MULTIAGENT_ENABLED=false

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
